	column 'EDAD (bins)' =
			IF(
				ISBLANK('adulto_limpio'[EDAD]),
				BLANK(),
				INT('adulto_limpio'[EDAD] / 10) * 10
			)
		formatString: 0
		lineageTag: 62d2d3ab-c065-41e7-8df1-d3e791d8be16
		summarizeBy: none

		extendedProperty GroupingMetadata =
				{
				  "version": 0,
				  "groupedColumns": [
				    {
				      "Column": {
				        "Expression": {
				          "SourceRef": {
				            "Entity": "adulto_limpio"
				          }
				        },
				        "Property": "EDAD"
				      }
				    }
				  ],
				  "binningMetadata": {
				    "binSize": {
				      "value": 10.0,
				      "unit": 0
				    }
				  }
				}

		annotation GroupingDesignState = {"Version":0,"Sources":[{"Name":"a","Entity":"adulto_limpio"}],"GroupedColumns":[{"Column":{"Expression":{"SourceRef":{"Source":"a"}},"Property":"EDAD"}}],"BinItem":{"Expression":{"Floor":{"Expression":{"Column":{"Expression":{"SourceRef":{"Source":"a"}},"Property":"EDAD"}},"Size":10.0}}}}

		annotation SummarizationSetBy = Automatic

	column 'Grupo Etario' =
			
			SWITCH(TRUE(),
			    adulto_limpio[EDAD] >= 18 && adulto_limpio[EDAD] <= 34, "18-34",
			    adulto_limpio[EDAD] >= 35 && adulto_limpio[EDAD] <= 49, "35-49",
			    adulto_limpio[EDAD] >= 50 && adulto_limpio[EDAD] <= 64, "50-64",
			    adulto_limpio[EDAD] >= 65, "65+",
			    BLANK()
			)
		lineageTag: 657dc77d-6a75-4f26-b4ab-d4d3564e6192
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

