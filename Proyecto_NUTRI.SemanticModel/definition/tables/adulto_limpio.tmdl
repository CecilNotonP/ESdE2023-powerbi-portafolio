table adulto_limpio
	lineageTag: 442840aa-8b89-4520-852f-8488376d740e

	measure 'Prevalencia Exceso Peso' =
			
			VAR PersonasConExceso = CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[IMC_INE] IN {3, 4})
			VAR TotalPersonasConIMC = CALCULATE(COUNTROWS(adulto_limpio), NOT(ISBLANK(adulto_limpio[IMC_INE])))
			RETURN
			DIVIDE(PersonasConExceso, TotalPersonasConIMC, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: a5c33cfd-123e-4ff7-80c6-f484facff493

	measure 'Total Adultos' =
			
			CALCULATE(COUNTROWS(adulto_limpio), NOT(ISBLANK(adulto_limpio[EDAD])))
		formatString: 0
		lineageTag: fa6c65b0-6bc5-4aa6-bd69-b93d59d33b43

	measure 'Prevalencia Hipertension' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[DIAG_TENSION_ALTA] = "Si"),
			    [Total Adultos]
			)
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: c36dd56d-4cda-412f-bdeb-6340bf482f6e

	measure 'Prevalencia Diabetes' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[DIAG_DIABETES] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 5f72de37-a412-4eb4-80f5-0d1ccc0ea330

	measure 'Prevalencia Colesterol' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[DIAG_COLESTEROL] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 67c96f1f-35ff-4d99-9732-96a89668494d

	measure 'Prevalencia Enf Corazon' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[DIAG_ENFERMEDADES_CORAZON] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 702bea10-3df0-4f24-8cc6-9060bcbe9e62

	measure 'Prevalencia Osteoporosis %' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[DIAG_OSTEOPOROSIS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 999568cd-7831-4272-ace6-0dd0e7437ce6

	measure 'Prevalencia Cualquier Patologia Nutricional %' =
			
			DIVIDE(
			    CALCULATE(
			        COUNTROWS(adulto_limpio),
			        adulto_limpio[DIAG_TENSION_ALTA] = "Si" ||
			        adulto_limpio[DIAG_DIABETES] = "Si" ||
			        adulto_limpio[DIAG_COLESTEROL] = "Si" ||
			        adulto_limpio[DIAG_ENFERMEDADES_CORAZON] = "Si"
			    ),
			    [Total Adultos]
			)
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 71f67304-6686-4f07-952a-f94d839860a3

	measure 'Usa Med Tension' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[MED_TENSION_CONSUMIDOS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: de638a4c-c179-4046-890b-5c37f9eba0ee

	measure 'Usa Med Diabetes' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[MED_DIABETES_CONSUMIDOS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 675aa066-6a04-4198-a98b-d082b62f4f5e

	measure 'Usa Med Colesterol' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[MED_COLESTEROL_CONSUMIDOS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 1b6c5212-cc46-479c-bdd7-85d1508fdf74

	measure 'Usa Med Adelgazar' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[MED_ADELGAZAR_CONSUMIDOS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: e7cdaa2a-0aad-43ea-bd14-c30232409256

	measure 'Prevalencia Sobrepeso' =
			
			VAR PersonasConSobrepeso = CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[IMC_INE] IN {3})
			VAR TotalPersonasConIMC = CALCULATE(COUNTROWS(adulto_limpio), NOT(ISBLANK(adulto_limpio[IMC_INE])))
			RETURN
			DIVIDE(PersonasConSobrepeso, TotalPersonasConIMC, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 4dead79a-275c-42aa-a64d-8d7f08f4a454

	measure 'Prevalencia Obesidad' =
			
			VAR PersonasConObesidad = CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[IMC_INE] IN {4})
			VAR TotalPersonasConIMC = CALCULATE(COUNTROWS(adulto_limpio), NOT(ISBLANK(adulto_limpio[IMC_INE])))
			RETURN
			DIVIDE(PersonasConObesidad, TotalPersonasConIMC, 0)
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: 5b79ccfe-cf2a-446b-a835-9fe9fb30ae24

	measure 'Total Adultos Texto' =
			
			FORMAT(CALCULATE(COUNTROWS(adulto_limpio), NOT(ISBLANK(adulto_limpio[EDAD]))), "#,##0")
		lineageTag: 7de6aae3-c41c-445f-82fe-1b7d6e894ecd

	measure 'Usa Med Corazon' =
			
			DIVIDE(CALCULATE(COUNTROWS(adulto_limpio), adulto_limpio[MED_CORAZON_CONSUMIDOS] = "Si"), [Total Adultos])
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 2a16fb43-7852-4134-ab99-5bb3063762e3

	measure '% Sedentario' = ```
			
			DIVIDE(
			    CALCULATE(COUNTROWS(adulto_limpio), 
			        adulto_limpio[Frecuencia Activ Fisica] = "No hago ejercicio. El tiempo libre lo ocupo de forma casi completamente sedentaria"),
			    [Total Adultos]
			)
			```
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: f762a674-683e-4918-9226-550012843fe6

	measure '% Activo Regular' = ```
			
			DIVIDE(
			    CALCULATE(COUNTROWS(adulto_limpio), 
			        adulto_limpio[Frecuencia Activ Fisica] = "Hago entrenamiento deportivo o físico varias veces a la semana"),
			    [Total Adultos]
			)
			```
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: 4d9c80aa-a67b-4a1a-8cb8-b2b6d0f0ff3a

		changedProperty = IsHidden

	measure '% Consume Comida Rapida Frecuente' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(adulto_limpio),
			        adulto_limpio[FREC_COMIDA_RAPIDA_PIZZA_HAMBURGUESAS] IN {"Una o más veces al día", "De 4 a 6 veces a la semana", "Tres veces a la semana"}),
			    [Total Adultos]
			)
		formatString: 0\ %;-0\ %;0\ %
		lineageTag: bc321f88-9b6f-476e-93d0-fe8d71ee61ac

	measure '% Consume Fruta Diario' =
			
			DIVIDE(
			    CALCULATE(COUNTROWS(adulto_limpio),
			        adulto_limpio[FREC_FRUTA_FRESCA_EXCLU_ZUMOS] = "Una o más veces al día"),
